@startuml strategic-report-generation

title Strategic Report Generation for 360° Feedback Cycle

skinparam DefaultFontName Helvetica
skinparam swimlaneBorderColor transparent
skinparam swimlaneBorderThickness 0
skinparam swimlaneTitleFontColor transparent
skinparam swimlaneTitleFontSize 1

|swimlane1|
start

partition "Cycle Stage Listener" {
    :Receive cycle.stage.processed event
    (cycleId, currentStage);

    if (currentStage == FINISHED?) then (no)
        stop
    else (yes)
    endif

    :Change cycle stage to PREPARING_REPORT;
}

partition "Strategic Reporting Service: Preconditions" {
    :Find cycle by id;
    if (cycle exists?) then (no)
        :Log error and re-throw
        NotFoundException;
        stop
    else (yes)
    endif

    :Find existing strategic report
    by cycleId;
    if (already exists?) then (yes)
        :Return existing report;
        stop
    else (no)
    endif

    :Search individual reports
    for the cycle;
    if (any reports found?) then (no)
        :Log error and re-throw
        NotFoundException;
        stop
    else (yes)
    endif
}

|swimlane2|

partition "Aggregate Reviews and Turnouts" {
    while (more individual reports?) is (yes)
        :Load review by reportId;
        :Collect review into set;
        :Initialise turnout entry
        (team %, other %);
    endwhile (no)
}

partition "Aggregate Per-Review Data" {
    while (more reviews?) is (yes)
        fork
            :Load ratee (user)
            and collect teamId / positionId;
        fork again
            :List respondents of review
            and collect their teamIds;
        fork again
            :List answers of review
            and collect questionIds;
        fork again
            :Get answer counts
            by respondent category;
        fork again
            :List reviewers of review;
        end fork

        :Cache teams / positions
        for collected ids;

        :Update per-category answer totals
        (SELF / TEAM / OTHER);

        if (self-assessment answers > 0?) then (yes)
            :Set ratee turnout = 100%;
        else (no)
            :Set ratee turnout = 0%;
        endif

        :Resolve competenceIds
        from collected questions;
        :Cache questions / competences
        for collected ids;
    endwhile (no)
}

partition "Build Competence Analytics" {
    :Load all report analytics
    in parallel (Promise.all);

    while (more competences?) is (yes)
        :Collect competence scores
        across all reports;
        fork
            :Compute average by SELF;
        fork again
            :Compute average by TEAM;
        fork again
            :Compute average by OTHER;
        end fork
        :Compute percentages
        vs MAX_SCORE;
        :Compute deltas
        (TEAM - SELF, OTHER - SELF);
        :Append StrategicReportAnalytics
        for the competence;
    endwhile (no)

    :Calculate competence summary totals
    (averages / percentages / deltas);
}

|swimlane3|

partition "Assemble Strategic Report" {
    :Aggregate unique ids
    (ratees, respondents, reviewers,
    teams, positions, competences, questions);
    :Compute average turnouts
    (ratees / teams / others);
    :Create StrategicReportDomain
    (counts + ids + totals);
    :Persist strategic report;
    :Persist strategic analytics
    (createMany);
}

partition "Generate Insights" {
    :Sort competences by title
    and map to entity averages
    (score, rating, delta);

    fork
        :Find HIGHEST_RATING entity;
    fork again
        :Find LOWEST_RATING entity;
    fork again
        :Find HIGHEST_DELTA entity;
    fork again
        :Find LOWEST_DELTA entity;
    end fork

    :Build 4 StrategicReportInsight records;
    :Persist insights (createMany);
}

partition "Finalise" {
    :Reload full strategic report;
    if (reload succeeded?) then (no)
        :Log error and re-throw
        NotFoundException;
        stop
    else (yes)
    endif

    :Change cycle stage to PUBLISHED;
    :Log success;
}

stop

@enduml
