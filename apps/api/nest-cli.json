{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "outDir": "./dist",
        "deleteOutDir": true,
        "tsConfigPath": "./tsconfig.json",
        "assets": ["**/*.assets"],
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "introspectComments": true
                }
            }
        ]
    }
}