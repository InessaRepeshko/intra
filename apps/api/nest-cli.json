    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "entryFile": "main",
    "outDir": "./dist",
    "compilerOptions": {
        "deleteOutDir": false,
        "tsConfigPath": "./tsconfig.json",
        "assets": [
            "**/*.assets"
