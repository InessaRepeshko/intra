{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "resolvePackageJsonExports": false,
        "resolveJsonModule": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "src/*": [
                "src/*"
            ],
            "@intra/api": [
                "src"
            ],
            "@intra/api/*": [
                "src/*"
            ],
            "@intra/api/common": [
                "src/common"
            ],
            "@intra/api/common/*": [
                "src/common/*"
            ],
            "@intra/database": [
                "../../packages/database/src/generated"
            ],
            "@intra/database/*": [
                "../../packages/database/src/generated/*"
            ],
            "@intra/shared-kernel": [
                "../../packages/shared-kernel/src"
            ],
            "@intra/shared-kernel/*": [
                "../../packages/shared-kernel/src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*spec.ts"
    ]
}