{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "resolvePackageJsonExports": false,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": ".",
        "declaration": true,
        "sourceMap": true,
        "paths": {
            "src/*": [
                "src/*"
            ],
            "@intra/api": [
                "src/contexts"
            ],
            "@intra/api/*": [
                "src/contexts/*"
            ],
            "@intra/test": [
                "test"
            ],
            "@intra/test/*": [
                "test/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "test/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test/web-e2e"
    ]
}