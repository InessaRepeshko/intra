  "author": "Inessa Repeshko",
  "scripts": {
    "// Environment variables": "",
    "env:dev": "dotenv -e ../../.env.development.local -v NODE_ENV=development",
    "env:test": "dotenv -e ../../.env.test -v NODE_ENV=test",
    "env:prod": "dotenv -e ../../.env.production -v NODE_ENV=production",
    "// Next.js Commands": "",
    "start:dev": "pnpm env:dev -- next dev",
    "build": "pnpm env:prod -- next build",
    "start:prod": "pnpm env:prod -- next start",
    "lint": "eslint . --cache",
    "format": "prettier --write \"**/*.{ts,tsx,css,js}\" --ignore-path ../../.prettierignore --no-error-on-unmatched-pattern"
