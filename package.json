{
  "name": "intra",
  "version": "1.0.0",
  "description": "",
  "author": "Inessa Repeshko",
  "private": true,
  "license": "MIT",
  "scripts": {
    "// --- Docker Commands ---": "",
    "docker:up": "docker-compose --env-file .env.development.local up -d",
    "docker:view": "docker ps -a",
    "docker:stop": "docker-compose stop",
    "docker:down": "docker-compose down -v",

    "// --- Prisma Basic Commands ---": "",
    "prisma:config": "npx prisma --config ./packages/database/prisma/prisma.config.ts",
    "prisma:dev": "dotenv -e .env.development.local -- npm run prisma:config --",
    "prisma:test": "dotenv -e .env.test -- npm run prisma:config --",

    "// --- Prisma Commands for DEV environment ---": "",
    "db:deploy": "npm run prisma:dev migrate deploy",
    "db:create": "npm run prisma:dev migrate dev",
    "db:generate": "npm run prisma:dev generate",
    "db:seed": "npm run prisma:dev db seed",
    "db:reset": "npm run prisma:dev migrate reset --force",
    "db:refresh": "npm run db:reset && npm run db:generate && npm run db:seed",

    "// --- Prisma Commands for TEST environment ---": "",
    "db:test:deploy": "npm run prisma:test migrate deploy",
    "db:test:generate": "npm run prisma:test generate",
    "db:test:reset": "npm run prisma:test migrate reset --force",
    "db:test:seed": "npm run prisma:test db seed",
    "db:test:refresh": "npm run db:test:reset && npm run db:test:generate && npm run db:test:seed",
   
    "// --- Environment Commands ---": "",
    "env:dev": "dotenv -e .env.development.local -v NODE_ENV=development",  
    "env:test": "dotenv -e .env.test -v NODE_ENV=test",
    "env:prod": "dotenv -e .env.production -v NODE_ENV=production",

    "// --- Running Commands ---": "",
    "start": "npm run env:dev -- nest start",
    "start:dev": "npm run env:dev -- nest start --watch",
    "start:test": "npm run env:test -- nest start",
    "start:debug": "npm run env:dev -- nest start --debug --watch",
    "start:prod": "npm run env:prod -- node dist/apps/api/src/main",
    "refresh": "npm run db:refresh && npm run start:dev",
    "refresh:test": "npm run db:test:refresh && npm run start:test",
    
    "// --- Testing Commands ---": "",
    "test": "npx jest --clearCache && npx jest",
    "test:unit": "npx jest --watch --config jest-unit.config.ts",
    "test:e2e": "npx jest --watch --config jest-e2e.config.ts",
    "test:watch": "npx jest --watch",
    "test:cov": "npx jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    
    "// --- Other Commands ---": "",
    "build": "nest build",
    "format": "prettier --write \"apps/api/src/**/*.ts\" \"apps/api/test/**/*.ts\"",
    "lint": "eslint \"{apps/api/src,apps/api/test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@prisma/adapter-mariadb": "^7.2.0",
    "prisma-dbml-generator": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-themes": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/testing": "^11.0.1",
    "@prisma/client": "^7.2.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.6",
    "@types/supertest": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "apps/api",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../../coverage",
    "testEnvironment": "node"
  },
  "overrides": {
    "cross-spawn": "^7.0.5",
    "tmp": "^0.2.3",
    "hono": "^4.11.4"
  }
}
