{
    "name": "@intra/root",
    "version": "1.0.0",
    "description": "360° Feedback Service",
    "private": true,
    "license": "MIT",
    "author": "Inessa Repeshko",
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "// --- Dev & Build ---": "",
        "dev": "turbo run dev --parallel",
        "dev:api": "turbo run dev --filter=@intra/api",
        "dev:web": "turbo run dev --filter=@intra/web",
        "build": "turbo run build",
        "build:api": "turbo run build --filter=@intra/api",
        "build:shared": "turbo run build --filter=@intra/shared-kernel",
        "build:database": "turbo run build --filter=@intra/database",
        "build:web": "turbo run build --filter=@intra/web",
        "clean": "rm -rf node_modules dist .turbo **/**/node_modules **/**/dist **/**/.turbo **/**/.next",
        "lint": "turbo run lint",
        "format": "turbo run format",
        "// --- Docker Commands ---": "",
        "docker:up": "dotenv -e .env.development.local -- docker-compose up -d",
        "docker:view": "docker ps -a",
        "docker:stop": "dotenv -e .env.development.local -- docker-compose stop",
        "docker:down": "dotenv -e .env.development.local -- docker-compose down -v --remove-orphans",
        "// --- Prisma Basic Commands ---": "",
        "prisma:config": "turbo run prisma:config --filter=@intra/database",
        "prisma:dev": "turbo run prisma:dev --filter=@intra/database",
        "prisma:test": "turbo run prisma:test --filter=@intra/database",
        "// --- Prisma Commands for DEV environment ---": "",
        "db:deploy": "turbo run db:deploy --filter=@intra/database",
        "db:create": "turbo run db:create --filter=@intra/database",
        "db:generate": "turbo run db:generate --filter=@intra/database",
        "db:seed": "turbo run db:seed --filter=@intra/database",
        "db:reset": "turbo run db:reset --filter=@intra/database",
        "db:refresh": "turbo run db:refresh --filter=@intra/database",
        "// --- Prisma Commands for PROD environment ---": "",
        "db:deploy:prod": "turbo run db:deploy:prod --filter=@intra/database",
        "db:generate:prod": "turbo run db:generate:prod --filter=@intra/database",
        "db:reset:prod": "turbo run db:reset:prod --filter=@intra/database",
        "db:seed:prod": "turbo run db:seed:prod --filter=@intra/database",
        "db:refresh:prod": "turbo run db:refresh:prod --filter=@intra/database",
        "// --- Environment Commands ---": "",
        "env:dev": "turbo run env:dev --filter=@intra/api",
        "env:test": "turbo run env:test --filter=@intra/api",
        "env:prod": "turbo run env:prod --filter=@intra/api",
        "// --- Running Commands ---": "",
        "start": "turbo run start",
        "start:dev": "turbo run start:dev",
        "start:test": "turbo run start:test --filter=@intra/api",
        "start:debug": "turbo run start:debug --filter=@intra/api",
        "start:prod": "turbo run start:prod",
        "start:prod:api": "turbo run start:prod --filter=@intra/api",
        "start:prod:web": "turbo run start:prod --filter=@intra/web",
        "start:web": "turbo run start:dev --filter=@intra/web",
        "start:api": "pnpm run docker:up && turbo run start:dev --filter=@intra/api",
        "refresh": "turbo run refresh --filter=@intra/api",
        "refresh:test": "turbo run refresh:test --filter=@intra/api",
        "// --- Testing Commands ---": "",
        "test": "turbo run test",
        "test:unit": "turbo run test:unit --filter=@intra/api",
        "test:e2e": "turbo run test:e2e --filter=@intra/api",
        "test:watch": "turbo run test:watch --filter=@intra/api",
        "test:cov": "turbo run test:cov --filter=@intra/api",
        "test:debug": "turbo run test:debug --filter=@intra/api"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.13",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.13",
        "@nestjs/platform-express": "^11.1.13",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/serve-static": "^5.0.4",
        "@prisma/adapter-pg": "^7.4.0",
        "pg": "^8.18.0",
        "prisma-dbml-generator": "^0.12.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "swagger-ui-themes": "^3.0.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.0.0",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/testing": "^11.1.13",
        "@next/eslint-plugin-next": "^16.1.6",
        "@prisma/client": "^7.4.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.2.3",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^17.3.1",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^15.0.0",
        "jest": "^30.2.0",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prisma": "^7.4.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "swagger-ui-express": "^5.0.1",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "turbo": "^2.8.9",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "apps/api",
        "moduleNameMapper": {
            "^src/(.*)$": "<rootDir>/src/$1"
        },
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../../coverage",
        "testEnvironment": "node"
    },
    "overrides": {
        "cross-spawn": "^7.0.5",
        "tmp": "^0.2.3",
        "hono": "^4.11.4"
    }
}
