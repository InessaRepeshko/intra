{
  "name": "intra",
  "version": "1.0.0",
  "description": "",
  "author": "Inessa Repeshko",
  "private": true,
  "license": "MIT",
  "scripts": {
    "docker:up": "docker-compose --env-file .env.development.local up -d",
    "docker:test:up": "docker-compose --env-file .env.test up -d",
    "docker:view": "docker ps -a",
    "docker:stop": "docker-compose stop",
    "docker:down": "docker-compose down -v",
    "migrate": "dotenv -e .env.development.local -- npx prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "migrate:create": "dotenv -e .env.development.local -- npx prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "migrate:generate": "dotenv -e .env.development.local -- npx prisma generate --schema packages/database/prisma/schema.prisma",
    "migrate:seed": "dotenv -e .env.development.local -- npx prisma db seed --schema packages/database/prisma/schema.prisma",
    "migrate:reset": "npm run migrate && npm run migrate:generate && npm run build && dotenv -e .env.development.local -- npx prisma migrate reset --force --schema packages/database/prisma/schema.prisma",
    "migrate:refresh": "npm run migrate:reset && npm run migrate:generate",
    "migrate:test": "dotenv -e .env.test -- npx prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "migrate:test:generate": "dotenv -e .env.test -- npx prisma generate --schema packages/database/prisma/schema.prisma",
    "migrate:test:reset": "dotenv -e .env.test -- npx prisma migrate reset --force --schema packages/database/prisma/schema.prisma",
    "migrate:test:refresh": "npm run migrate:test:reset && npm run migrate:test:generate",
    "migrate:test:seed": "dotenv -e .env.test -- npx prisma db seed --schema packages/database/prisma/schema.prisma",
    "start": "dotenv -e .env.development.local -v NODE_ENV=development -- nest start",
    "start:dev": "dotenv -e .env.development.local -v NODE_ENV=development -- nest start --watch",
    "start:test": "dotenv -e .env.test -v NODE_ENV=test -- nest start",
    "start:debug": "dotenv -e .env.development.local -v NODE_ENV=development -- nest start --debug --watch",
    "start:prod": "dotenv -e .env.production -v NODE_ENV=production -- node dist/apps/api/src/main",
    "refresh": "npm run migrate:refresh; npm run start:dev",
    "refresh:test": "npm run migrate:test:refresh; npm run start:test",
    "test": "npx jest --clearCache && npx jest",
    "test:unit": "npx jest --watch --config jest-unit.config.ts",
    "test:e2e": "npx jest --watch --config jest-e2e.config.ts",
    "test:watch": "npx jest --watch",
    "test:cov": "npx jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "build": "nest build",
    "format": "prettier --write \"apps/api/src/**/*.ts\" \"apps/api/test/**/*.ts\"",
    "lint": "eslint \"{apps/api/src,apps/api/test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@prisma/client": "^6.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-themes": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "apps/api",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../../coverage",
    "testEnvironment": "node"
  }
}
