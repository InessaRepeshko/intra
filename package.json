{
  "name": "intra-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "docker:up": "docker-compose --env-file .env.development.local up -d",
    "docker:view": "docker ps -a",
    "docker:stop": "docker-compose stop",
    "docker:down": "docker-compose down -v",

    "setup:db": "ts-node src/setupdb.ts",
    "migrate": "dotenv -e .env.development.local -- npx prisma migrate deploy",
    "migrate:create": "dotenv -e .env.development.local -- npx prisma migrate dev",
    "migrate:generate": "dotenv -e .env.development.local -- npx prisma generate",
    "migrate:seed": "dotenv -e .env.development.local -- npx prisma db seed",
    "migrate:reset": "npm run migrate && npm run migrate:generate && npm run build && dotenv -e .env.development.local -- npx prisma migrate reset --force",
    "migrate:refresh": "npm run migrate:reset && npm run migrate:generate",
    
    "start": "nest start",
    "start:dev": "dotenv -e .env.development.local -v NODE_ENV=development -- nest start --watch",
    "start:debug": "dotenv -e .env.development.local -v NODE_ENV=development -- nest start --debug --watch",
    "start:prod": "dotenv -e .env.production -v NODE_ENV=production -- node dist/src/main",
    "refresh": "npm run migrate:refresh; npm run start:dev",
    
    "test": "npx jest --clearCache && npx jest",
    "test:unit": "npx jest --watch --config jest-unit.config.ts",
    "test:e2e": "npx jest --watch --config jest-e2e.config.ts",
    "test:watch": "npx jest --watch",
    "test:cov": "npx jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.19.1",
    "prisma": "^6.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
