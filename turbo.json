{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "^db:generate",
                "^format",
                "format"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ],
            "cache": true
        },
        "prisma:config": {
            "cache": false
        },
        "prisma:dev": {
            "cache": false
        },
        "prisma:test": {
            "cache": false
        },
        "db:generate": {
            "dependsOn": [
                "^db:generate"
            ],
            "inputs": [
                "src/prisma/schema.prisma",
                "src/prisma/prisma.config.ts"
            ],
            "outputs": [
                "dist/generated/**"
            ],
            "cache": true
        },
        "db:deploy": {
            "cache": false
        },
        "db:create": {
            "cache": false
        },
        "db:seed": {
            "cache": false
        },
        "db:reset": {
            "cache": false
        },
        "db:refresh": {
            "cache": false
        },
        "db:deploy:prod": {
            "cache": false
        },
        "db:generate:prod": {
            "cache": false
        },
        "db:seed:prod": {
            "cache": false
        },
        "db:reset:prod": {
            "cache": false
        },
        "db:refresh:prod": {
            "cache": false
        },
        "format": {
            "cache": false,
            "outputLogs": "errors-only"
        },
        "lint": {
            "outputs": [],
            "cache": true
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "outputs": [],
            "cache": true
        },
        "test:unit": {
            "cache": false,
            "persistent": true
        },
        "test:e2e": {
            "cache": false,
            "persistent": true
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "test:cov": {
            "cache": false
        },
        "test:debug": {
            "cache": false,
            "persistent": true
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "cache": false
        },
        "start:dev": {
            "cache": false,
            "persistent": true
        },
        "start:test": {
            "cache": false
        },
        "start:debug": {
            "cache": false,
            "persistent": true
        },
        "start:prod": {
            "cache": false
        },
        "refresh": {
            "cache": false
        },
        "refresh:test": {
            "cache": false
        }
    }
}