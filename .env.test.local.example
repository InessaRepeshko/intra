# Local-only secrets that the `.gitignore` keeps out of the repo.
# Copy this file to `.env.test.local` and fill in the real values to enable
# `--record` runs against Cypress Cloud from your machine.
#
#   cp .env.test.local.example .env.test.local
#   $EDITOR .env.test.local
#
# `.gitignore` already covers `.env.test.local` and any `.env.*.local`, so
# nothing here ever reaches the remote.

# Cypress Cloud — public id of the project on cloud.cypress.io
CYPRESS_PROJECT_ID=

# Cypress Cloud — secret record key. NEVER commit, NEVER paste in chat.
CYPRESS_RECORD_KEY=
