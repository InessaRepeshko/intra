  "info": {
    "title": "Intra API",
    "description": "API documentation for Intra",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "{protocol}://{host}:{port}",
      "description": "Development server",
      "variables": {
        "protocol": {
          "default": "http"
        },
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "8080"
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "description": "User's first name",
            "example": "Valerii"
          },
          "secondName": {
            "type": "object",
            "description": "User's second name",
            "example": "Velychko"
          },
          "lastName": {
            "type": "string",
            "description": "User's last name",
            "example": "Valeriiovych"
          },
          "email": {
            "type": "string",
            "description": "User's email",
            "example": "valerii.velychko@example.com"
          },
          "passwordHash": {
            "type": "string",
            "description": "Precomputed password hash or placeholder for external authentication",
            "example": "__external_auth__"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ],
            "default": "active",
            "description": "User's status"
          },
          "positionId": {
            "type": "number",
            "description": "Position ID",
            "example": 1
          },
          "teamId": {
            "type": "number",
            "description": "Team ID",
            "example": 10
          },
          "managerId": {
            "type": "number",
            "description": "Manager ID",
            "example": 2
          }
        },
        "required": [
          "firstName",
          "lastName",
          "email"
        ]
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "firstName": {
            "type": "string",
            "example": "Valerii"
          },
          "secondName": {
            "type": "object",
            "example": "Velychko",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "example": "Valeriiovych"
          },
          "fullName": {
            "type": "object",
            "example": "Valerii Valeriiovych Velychko",
            "nullable": true
          },
          "email": {
            "type": "string",
            "example": "valerii.velychko@example.com"
          },
          "status": {
            "type": "string",
            "enum": [
