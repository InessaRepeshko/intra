{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "declaration": true,
        "sourceMap": true,
        "paths": {
            "src/*": [
                "src/*"
            ],
            "@intra/shared-kernel": [
                "src/index.ts"
            ],
            "@intra/shared-kernel/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}