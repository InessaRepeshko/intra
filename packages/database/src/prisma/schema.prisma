generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../../dist/generated"
}

generator dbml {
  provider = "prisma-dbml-generator"
  schema   = "packages/database/src/prisma/schema.prisma"
  output   = "./dbml"
}

datasource db {
  provider = "postgresql"
}

/**
 * ==================== Identity ====================
 */

enum IdentityRole {
  ADMIN    @map("admin")
  HR       @map("hr")
  MANAGER  @map("manager")
  EMPLOYEE @map("employee")

  @@map("identity_role")
}

enum IdentityStatus {
  INACTIVE @map("inactive")
  ACTIVE   @map("active")

  @@map("identity_status")
}

model User {
  id         Int            @id @default(autoincrement())
  firstName  String         @map("first_name") @db.VarChar(100)
  secondName String?        @map("second_name") @db.VarChar(100)
  lastName   String         @map("last_name") @db.VarChar(100)
  fullName   String         @map("full_name") @db.VarChar(302)
  email      String         @unique @db.VarChar(100)
  avatarUrl  String?        @map("avatar_url") @db.Text
  status     IdentityStatus @default(ACTIVE)
  positionId Int?           @map("position_id")
  teamId     Int?           @map("team_id")
  managerId  Int?           @map("manager_id")
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // --- Identity ---
  userRoles UserRole[]

  // --- Organisation ---
  teamHead     Team[]           @relation("team_head")
  memberships  TeamMembership[] @relation("team_memberships")
  manager      User?            @relation("user_hierarchy", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates User[]           @relation("user_hierarchy")

  // --- Feedback360 (HR/Admin side) ---
  managedCycles  Cycle[]  @relation("managed_cycles")
  managedReviews Review[] @relation("managed_reviews")

  // --- Feedback360 (Participant side) ---
  reviewsAsRatee     Review[]             @relation("reviews_as_ratee")
  responses          Respondent[]         @relation("user_responses")
  reviewsAsReviewer  Reviewer[]           @relation("reviews_as_reviewer")
  reviewsAsManager   Review[]             @relation("review_as_manager")
  clusterScores      ClusterScore[]       @relation("cluster_ratee_scores")
  stageChangeHistory ReviewStageHistory[] @relation("stage_change_actor")

  @@index([managerId])
  @@index([positionId])
  @@index([teamId])
  @@index([fullName])
  @@index([status])
  @@map("identity_users")
}

model Role {
  id          Int          @id @default(autoincrement())
  code        IdentityRole @unique
  title       String       @db.VarChar(255)
  description String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  userRoles UserRole[]

  @@map("identity_roles")
}

model UserRole {
  id         Int          @id @default(autoincrement())
  userId     Int          @map("user_id")
  roleCode   IdentityRole @map("role_code")
  assignedAt DateTime     @default(now()) @map("assigned_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role Role @relation(fields: [roleCode], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, roleCode])
  @@index([roleCode])
  @@index([userId])
  @@map("identity_users_roles")
}

/**
 * ==================== Organisation ====================
 */

model Team {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  headId      Int?     @map("head_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  memberships TeamMembership[]
  head        User?            @relation("team_head", fields: [headId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews     Review[]
  respondents Respondent[]
  reviewers   Reviewer[]

  @@index([headId])
  @@map("org_teams")
}

model TeamMembership {
  id        Int      @id @default(autoincrement())
  teamId    Int      @map("team_id")
  memberId  Int      @map("member_id")
  isPrimary Boolean? @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  team   Team @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member User @relation("team_memberships", fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([teamId, memberId, isPrimary])
  @@index([teamId])
  @@index([memberId])
  @@map("org_team_memberships")
}

model Position {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  competences               PositionCompetenceRelation[]
  reviews                   Review[]
  questionTemplateRelations PositionQuestionTemplateRelation[]
  superiors                 PositionHierarchy[]                @relation("superior_position")
  subordinates              PositionHierarchy[]                @relation("subordinate_position")
  respondents               Respondent[]

  @@map("org_positions")
}

model PositionHierarchy {
  id                    Int      @id @default(autoincrement())
  superiorPositionId    Int      @map("superior_position_id")
  subordinatePositionId Int      @map("subordinate_position_id")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  superior    Position @relation("superior_position", fields: [superiorPositionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinate Position @relation("subordinate_position", fields: [subordinatePositionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([superiorPositionId, subordinatePositionId])
  @@index([subordinatePositionId])
  @@map("org_position_hierarchies")
}

/**
 * ==================== Library ====================
 */

enum AnswerType {
  NUMERICAL_SCALE @map("numerical_scale")
  TEXT_FIELD      @map("text_field")

  @@map("library_answer_type")
}

enum QuestionTemplateStatus {
  ARCHIVE @map("archive")
  ACTIVE  @map("active")

  @@map("question_template_status")
}

model Competence {
  id          Int      @id @default(autoincrement())
  code        String?  @unique @db.VarChar(100)
  title       String   @unique @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  positions                 PositionCompetenceRelation[]
  questionTemplateRelations CompetenceQuestionTemplateRelation[]
  questionTemplates         QuestionTemplate[]
  reviewQuestions           Question[]
  reviewQuestionRelations   ReviewQuestionRelation[]
  clusters                  Cluster[]
  reportAnalytics           ReportAnalytics[]

  @@map("library_competences")
}

model Cluster {
  id           Int      @id @default(autoincrement())
  competenceId Int      @map("competence_id")
  lowerBound   Decimal  @map("lower_bound") @db.Decimal(10, 4)
  upperBound   Decimal  @map("upper_bound") @db.Decimal(10, 4)
  title        String   @db.VarChar(255)
  description  String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  clusterScores         ClusterScore[]
  clusterScoreAnalytics ClusterScoreAnalytics[]
  competence            Competence              @relation(fields: [competenceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([competenceId, lowerBound, upperBound])
  @@index([competenceId])
  @@map("library_clusters")
}

model QuestionTemplate {
  id                  Int                    @id @default(autoincrement())
  title               String                 @db.Text
  answerType          AnswerType             @map("answer_type")
  competenceId        Int                    @map("competence_id")
  isForSelfassessment Boolean?               @default(false) @map("is_for_selfassessment")
  status              QuestionTemplateStatus @default(ACTIVE) @map("status")
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  competence        Competence                           @relation(fields: [competenceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  competences       CompetenceQuestionTemplateRelation[]
  positionRelations PositionQuestionTemplateRelation[]
  reviewQuestions   Question[]

  @@index([competenceId])
  @@map("library_question_templates")
}

model PositionQuestionTemplateRelation {
  id                 Int      @id @default(autoincrement())
  positionId         Int      @map("position_id")
  questionTemplateId Int      @map("question_template_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  position         Position         @relation(fields: [positionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  questionTemplate QuestionTemplate @relation(fields: [questionTemplateId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([questionTemplateId, positionId])
  @@index([positionId])
  @@map("library_position_question_template_relations")
}

model PositionCompetenceRelation {
  id           Int      @id @default(autoincrement())
  positionId   Int      @map("position_id")
  competenceId Int      @map("competence_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  position   Position   @relation(fields: [positionId], references: [id])
  competence Competence @relation(fields: [competenceId], references: [id])

  @@unique([positionId, competenceId])
  @@map("library_position_competence_relations")
}

model CompetenceQuestionTemplateRelation {
  id                 Int      @id @default(autoincrement())
  competenceId       Int      @map("competence_id")
  questionTemplateId Int      @map("question_template_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  competence       Competence       @relation(fields: [competenceId], references: [id])
  questionTemplate QuestionTemplate @relation(fields: [questionTemplateId], references: [id])

  @@unique([competenceId, questionTemplateId])
  @@map("library_competence_question_template_relations")
}

/**
 * ==================== Feedback360 ====================
 */

enum CycleStage {
  CANCELED @map("canceled")
  NEW      @map("new")
  ACTIVE   @map("active")
  FINISHED @map("finished")
  ARCHIVED @map("archived")

  @@map("feedback360_cycle_stage")
}

enum ResponseStatus {
  PENDING     @map("pending")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELED    @map("canceled")

  @@map("feedback360_response_status")
}

enum ReviewStage {
  CANCELED             @map("canceled")
  VERIFICATION_BY_HR   @map("verification_by_hr")
  VERIFICATION_BY_USER @map("verification_by_user")
  REJECTED             @map("rejected")
  SELF_ASSESSMENT      @map("self_assessment")
  WAITING_TO_START     @map("waiting_to_start")
  IN_PROGRESS          @map("in_progress")
  PREPARING_REPORT     @map("preparing_report")
  PROCESSING_BY_HR     @map("processing_by_hr")
  PUBLISHED            @map("published")
  ANALYSIS             @map("analysis")
  FINISHED             @map("finished")

  @@map("feedback360_review_stage")
}

enum RespondentCategory {
  SELF_ASSESSMENT @map("self_assessment")
  TEAM            @map("team")
  OTHER           @map("other")

  @@map("feedback360_respondent_category")
}

model Cycle {
  id                      Int        @id @default(autoincrement())
  title                   String     @db.VarChar(255)
  description             String?    @db.Text
  hrId                    Int        @map("hr_id")
  stage                   CycleStage @default(NEW)
  isActive                Boolean?   @default(true) @map("is_active")
  minRespondentsThreshold Int        @default(3) @map("min_respondents_threshold")
  startDate               DateTime   @map("start_date") @db.Timestamp(0)
  reviewDeadline          DateTime?  @map("review_deadline") @db.Timestamp(0)
  approvalDeadline        DateTime?  @map("approval_deadline") @db.Timestamp(0)
  responseDeadline        DateTime?  @map("response_deadline") @db.Timestamp(0)
  endDate                 DateTime   @map("end_date") @db.Timestamp(0)
  createdAt               DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt               DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  hr                    User                    @relation("managed_cycles", fields: [hrId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clusterScores         ClusterScore[]
  clusterScoreAnalytics ClusterScoreAnalytics[]
  reviews               Review[]
  reports               Report[]
  reviewQuestions       Question[]

  @@index([hrId])
  @@index([stage])
  @@map("feedback360_cycles")
}

model Review {
  id                   Int         @id @default(autoincrement())
  rateeId              Int         @map("ratee_id")
  rateeFullName        String      @map("ratee_full_name") @db.VarChar(302)
  rateePositionId      Int         @map("ratee_position_id")
  rateePositionTitle   String      @map("ratee_position_title") @db.Text
  hrId                 Int         @map("hr_id")
  hrFullName           String      @map("hr_full_name") @db.VarChar(302)
  hrNote               String?     @map("hr_note") @db.Text
  teamId               Int?        @map("team_id")
  teamTitle            String?     @map("team_title") @db.Text
  managerId            Int?        @map("manager_id")
  managerFullName      String?     @map("manager_full_name") @db.VarChar(302)
  managerPositionId    Int?        @map("manager_position_id")
  managerPositionTitle String?     @map("manager_position_title") @db.Text
  cycleId              Int?        @map("cycle_id")
  reportId             Int?        @map("report_id")
  stage                ReviewStage @default(VERIFICATION_BY_HR)
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  ratee    User     @relation("reviews_as_ratee", fields: [rateeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hr       User     @relation("managed_reviews", fields: [hrId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycle    Cycle?   @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  position Position @relation(fields: [rateePositionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  team     Team?    @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manager  User?    @relation("review_as_manager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  answers                 Answer[]
  reviewQuestionRelations ReviewQuestionRelation[]
  report                  Report?
  respondents             Respondent[]
  reviewers               Reviewer[]
  clusterScores           ClusterScore[]
  reviewStageHistories    ReviewStageHistory[]

  @@index([cycleId])
  @@index([hrId])
  @@index([rateePositionId])
  @@index([teamId])
  @@index([managerId])
  @@index([rateeId])
  @@index([stage])
  @@index([createdAt])
  @@map("feedback360_reviews")
}

model Question {
  id                  Int        @id @default(autoincrement())
  cycleId             Int?       @map("cycle_id")
  questionTemplateId  Int?       @map("question_template_id")
  title               String     @db.Text
  answerType          AnswerType @map("answer_type")
  competenceId        Int?       @map("competence_id")
  isForSelfassessment Boolean?   @default(false) @map("is_for_selfassessment")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamp(0)

  cycle                   Cycle?                   @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  questionTemplate        QuestionTemplate?        @relation(fields: [questionTemplateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  competence              Competence?              @relation(fields: [competenceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  answers                 Answer[]
  reviewQuestionRelations ReviewQuestionRelation[]
  reportComments          ReportComment[]
  reportAnalytics         ReportAnalytics[]

  @@index([cycleId])
  @@index([questionTemplateId])
  @@index([competenceId])
  @@map("feedback360_questions")
}

model ReviewQuestionRelation {
  id                  Int        @id @default(autoincrement())
  reviewId            Int        @map("review_id")
  questionId          Int        @map("question_id")
  questionTitle       String     @map("question_title") @db.Text
  answerType          AnswerType @map("answer_type")
  competenceId        Int        @map("competence_id")
  competenceTitle     String     @map("competence_title") @db.Text
  isForSelfassessment Boolean?   @default(false) @map("is_for_selfassessment")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamp(0)

  review     Review     @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  competence Competence @relation(fields: [competenceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([reviewId, questionId])
  @@index([reviewId])
  @@index([questionId])
  @@index([competenceId])
  @@map("feedback360_review_question_relations")
}

model Answer {
  id                 Int                @id @default(autoincrement())
  reviewId           Int                @map("review_id")
  questionId         Int                @map("review_question_id")
  respondentCategory RespondentCategory @map("respondent_category")
  answerType         AnswerType         @default(NUMERICAL_SCALE) @map("answer_type")
  numericalValue     Int?               @map("numerical_value") @db.SmallInt
  textValue          String?            @map("text_value") @db.Text
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamp(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review   Review   @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([reviewId])
  @@index([questionId])
  @@index([respondentCategory])
  @@index([createdAt])
  @@map("feedback360_answers")
}

model ClusterScore {
  id           Int      @id @default(autoincrement())
  cycleId      Int?     @map("cycle_id")
  clusterId    Int      @map("cluster_id")
  rateeId      Int      @map("ratee_id")
  reviewId     Int      @map("review_id")
  score        Decimal  @db.Decimal(10, 4)
  answersCount Int      @default(0) @map("answers_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  ratee   User    @relation("cluster_ratee_scores", fields: [rateeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycle   Cycle?  @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review  Review  @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([clusterId, rateeId])
  @@index([cycleId])
  @@index([clusterId])
  @@index([rateeId])
  @@index([reviewId])
  @@map("feedback360_cluster_scores")
}

model ClusterScoreAnalytics {
  id             Int      @id @default(autoincrement())
  cycleId        Int      @map("cycle_id")
  clusterId      Int      @map("cluster_id")
  employeesCount Int      @default(0) @map("employees_count")
  lowerBound     Decimal  @map("lower_bound") @db.Decimal(10, 4)
  upperBound     Decimal  @map("upper_bound") @db.Decimal(10, 4)
  minScore       Decimal  @map("min_score") @db.Decimal(10, 4)
  maxScore       Decimal  @map("max_score") @db.Decimal(10, 4)
  averageScore   Decimal  @map("average_score") @db.Decimal(10, 4)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  cycle   Cycle   @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cycleId, clusterId])
  @@index([cycleId])
  @@index([clusterId])
  @@map("feedback360_cluster_score_analytics")
}

model Respondent {
  id             Int                @id @default(autoincrement())
  reviewId       Int                @map("review_id")
  respondentId   Int                @map("respondent_id")
  fullName       String             @map("full_name") @db.VarChar(302)
  category       RespondentCategory @map("category")
  responseStatus ResponseStatus     @default(PENDING) @map("response_status")
  respondentNote String?            @map("respondent_note") @db.Text
  hrNote         String?            @map("hr_note") @db.Text
  positionId     Int                @map("position_id")
  positionTitle  String             @map("position_title") @db.Text
  teamId         Int?               @map("team_id")
  teamTitle      String?            @map("team_title") @db.Text
  invitedAt      DateTime?          @map("invited_at") @db.Timestamp(0)
  canceledAt     DateTime?          @map("canceled_at") @db.Timestamp(0)
  respondedAt    DateTime?          @map("responded_at") @db.Timestamp(0)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user               User      @relation("user_responses", fields: [respondentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review             Review    @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  respondentPosition Position? @relation(fields: [positionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  respondentTeam     Team?     @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([respondentId, reviewId])
  @@index([reviewId])
  @@index([responseStatus])
  @@index([respondentId])
  @@index([positionId])
  @@index([teamId])
  @@index([respondentId, responseStatus])
  @@map("feedback360_respondents")
}

model Reviewer {
  id            Int      @id @default(autoincrement())
  reviewId      Int      @map("review_id")
  reviewerId    Int      @map("reviewer_id")
  fullName      String   @map("full_name") @db.VarChar(302)
  positionId    Int      @map("position_id")
  positionTitle String   @map("position_title") @db.Text
  teamId        Int?     @map("team_id")
  teamTitle     String?  @map("team_title") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user   User   @relation("reviews_as_reviewer", fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review Review @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([reviewId, reviewerId])
  @@index([reviewId])
  @@index([reviewerId])
  @@index([teamId])
  @@map("feedback360_reviewers")
}

model ReviewStageHistory {
  id            Int         @id @default(autoincrement())
  reviewId      Int         @map("review_id")
  fromStage     ReviewStage @map("from_stage")
  toStage       ReviewStage @map("to_stage")
  changedById   Int?        @map("changed_by_id")
  changedByName String?     @map("changed_by_name") @db.VarChar(302)
  reason        String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(0)

  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  changedBy User?  @relation("stage_change_actor", fields: [changedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([reviewId])
  @@index([changedById])
  @@index([createdAt])
  @@map("feedback360_review_stage_history")
}

/**
 * ==================== Reporting ====================
 */

enum EntityType {
  QUESTION   @map("question")
  COMPETENCE @map("competence")

  @@map("reporting_entity_type")
}

enum CommentSentiment {
  NEGATIVE @map("negative")
  POSITIVE @map("positive")

  @@map("reporting_comment_sentiment")
}

model Report {
  id                            Int      @id @default(autoincrement())
  reviewId                      Int      @unique() @map("review_id")
  cycleId                       Int?     @map("cycle_id")
  respondentCount               Int      @map("respondent_count")
  turnoutPctOfTeam              Decimal? @map("turnout_pct_of_team") @db.Decimal(10, 4)
  turnoutPctOfOther             Decimal? @map("turnout_pct_of_other") @db.Decimal(10, 4)
  questionTotAvgBySelf          Decimal? @map("question_tot_avg_by_self") @db.Decimal(10, 4)
  questionTotAvgByTeam          Decimal? @map("question_tot_avg_by_team") @db.Decimal(10, 4)
  questionTotAvgByOthers        Decimal? @map("question_tot_avg_by_others") @db.Decimal(10, 4)
  questionTotPctBySelf          Decimal? @map("question_tot_pct_by_self") @db.Decimal(10, 4)
  questionTotPctByTeam          Decimal? @map("question_tot_pct_by_team") @db.Decimal(10, 4)
  questionTotPctByOthers        Decimal? @map("question_tot_pct_by_others") @db.Decimal(10, 4)
  questionTotDeltaPctByTeam     Decimal? @map("question_tot_delta_pct_by_team") @db.Decimal(10, 4)
  questionTotDeltaPctByOthers   Decimal? @map("question_tot_delta_pct_by_others") @db.Decimal(10, 4)
  competenceTotAvgBySelf        Decimal? @map("competence_tot_avg_by_self") @db.Decimal(10, 4)
  competenceTotAvgByTeam        Decimal? @map("competence_tot_avg_by_team") @db.Decimal(10, 4)
  competenceTotAvgByOthers      Decimal? @map("competence_tot_avg_by_others") @db.Decimal(10, 4)
  competenceTotPctBySelf        Decimal? @map("competence_tot_pct_by_self") @db.Decimal(10, 4)
  competenceTotPctByTeam        Decimal? @map("competence_tot_pct_by_team") @db.Decimal(10, 4)
  competenceTotPctByOthers      Decimal? @map("competence_tot_pct_by_others") @db.Decimal(10, 4)
  competenceTotDeltaPctByTeam   Decimal? @map("competence_tot_delta_pct_by_team") @db.Decimal(10, 4)
  competenceTotDeltaPctByOthers Decimal? @map("competence_tot_delta_pct_by_others") @db.Decimal(10, 4)
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  review    Review            @relation(fields: [reviewId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycle     Cycle?            @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  analytics ReportAnalytics[]
  comments  ReportComment[]

  @@index([cycleId])
  @@map("reporting_reports")
}

model ReportAnalytics {
  id                         Int        @id @default(autoincrement())
  reportId                   Int        @map("report_id")
  entityType                 EntityType @map("entity_type")
  questionId                 Int?       @map("question_id")
  questionTitle              String?    @map("question_title") @db.Text
  competenceId               Int?       @map("competence_id")
  competenceTitle            String?    @map("competence_title") @db.Text
  averageBySelfAssessment    Decimal?   @map("average_by_self_assessment") @db.Decimal(10, 4)
  averageByTeam              Decimal?   @map("average_by_team") @db.Decimal(10, 4)
  averageByOther             Decimal?   @map("average_by_other") @db.Decimal(10, 4)
  percentageBySelfAssessment Decimal?   @map("percentage_by_self_assessment") @db.Decimal(10, 4)
  percentageByTeam           Decimal?   @map("percentage_by_team") @db.Decimal(10, 4)
  percentageByOther          Decimal?   @map("percentage_by_other") @db.Decimal(10, 4)
  deltaPercentageByTeam      Decimal?   @map("delta_percentage_by_team") @db.Decimal(10, 4)
  deltaPercentageByOther     Decimal?   @map("delta_percentage_by_other") @db.Decimal(10, 4)
  createdAt                  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)

  report     Report      @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  question   Question?   @relation(fields: [questionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  competence Competence? @relation(fields: [competenceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([reportId])
  @@index([questionId])
  @@index([competenceId])
  @@map("reporting_analytics")
}

model ReportComment {
  id                   Int                  @id @default(autoincrement())
  reportId             Int                  @map("report_id")
  questionId           Int                  @map("question_id")
  questionTitle        String               @map("question_title") @db.Text
  comment              String               @db.Text
  respondentCategories RespondentCategory[] @map("respondent_categories")
  commentSentiment     CommentSentiment?    @default(POSITIVE) @map("comment_sentiment")
  numberOfMentions     Int                  @map("number_of_mentions")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamp(0)

  report   Report    @relation(fields: [reportId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  question Question? @relation(fields: [questionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([reportId])
  @@index([questionId])
  @@map("reporting_comments")
}
